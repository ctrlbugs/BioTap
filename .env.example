# SMTP Configuration (required for email features)
# Example BioTap contact mailbox configuration
SMTP_HOST=premium326.web-hosting.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@biotapapp.com
SMTP_PASSWORD=
SMTP_FROM=contact@biotapapp.com
CONTACT_FORM_TO=contact@biotapapp.com

# Optional: Override base URL for emails (defaults to https://biotapapp.com)
NEXT_PUBLIC_BASE_URL=https://biotapapp.com
BASE_URL=https://biotapapp.com

# Optional: Backend API URL (defaults to https://dashboard.sinergianegotium.com in production)
BACKEND_API_URL=

# Email Limits (optional)
EMAIL_DAILY_LIMIT=500
EMAIL_RATE_LIMIT_DELAY=100
